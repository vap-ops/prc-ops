# Copy this file to .env.local for local development. Never commit .env.local.

# Supabase
# Required once the Supabase integration ships. Get these from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (server-side only — never expose to the browser)
# Required once LINE Login ships. Get these from the LINE Developers console.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Application
# Override in production with the canonical public URL (e.g. https://app.example.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000
