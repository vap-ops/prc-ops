# Copy this file to .env.local for local development. Never commit .env.local.

# Supabase
# Required once the Supabase integration ships. Get these from the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Login (server-side only — never expose to the browser)
# Required once LINE Login ships. Get these from the LINE Developers console.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# LINE Messaging API + notification drain (spec 32 / ADR 0037).
# OPTIONAL — leave commented out until activation; the drain endpoint
# answers 503 until both are set. Token comes from the Messaging API
# channel (distinct from the Login channel above); the drain secret is any
# 32+ random chars, mirrored into Supabase Vault as
# notification_drain_secret (see go-live checklist §8).
# LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# NOTIFICATION_DRAIN_SECRET=

# Application
# Override in production with the canonical public URL (e.g. https://app.example.com).
NEXT_PUBLIC_APP_URL=http://localhost:3000
